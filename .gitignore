# ============================================================
#  .gitignore вЂ” Odoo 19 Community (Docker + mГіdulos custom)
#  Cubre: Python, Odoo runtime, Docker, editors, OS
# ============================================================


# ------------------------------------------------------------
# SECRETOS Y CONFIGURACIГ“N LOCAL  в†ђ nunca versionar
# ------------------------------------------------------------
.env
.env.local
.env.*.local
infra/config/odoo.conf    # Contiene master_password, db_password, etc.
*.secret
secrets/


# ------------------------------------------------------------
# ODOO вЂ” archivos generados en runtime
# ------------------------------------------------------------

# Filestore (adjuntos, imГЎgenes, documentos subidos por usuarios)
filestore/
/var/lib/odoo/filestore/

# Sesiones web
.sessions/
/var/lib/odoo/sessions/

# Logs
*.log
logs/
/var/log/odoo/

# CachГ© de assets compilados (JS/CSS minificado)
web/static/lib/
# Nota: si tus addons generan assets compilados localmente:
odoo/addons/**/static/description/icon_generated.*

# Archivos .pyc y cachГ© de Python en mГіdulos Odoo
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.pytest_cache/

# Migraciones generadas automГЎticamente (no las de tu autorГ­a)
# Descomenta si no versionar migraciones:
# odoo/addons/**/migrations/


# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Entornos virtuales (si alguien instala Odoo sin Docker)
venv/
.venv/
env/
.env/
ENV/
pip-selfcheck.json

# DistribuciГіn / empaquetado
dist/
build/
*.egg-info/
*.egg
MANIFEST

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# pytest
.pytest_cache/
nosetests.xml
test-results/


# ------------------------------------------------------------
# DOCKER
# ------------------------------------------------------------

# VolГєmenes montados localmente (datos de PostgreSQL, filestore)
volumes/
pgdata/
odoo-data/
db-data/

# Override para desarrollo local (puede tener puertos, bind mounts personales)
infrastructure/docker-compose.override.yml

# Directorios creados automГЎticamente por Docker cuando un bind-mount
# no existe en el host вЂ” Docker los crea vacГ­os, no deben versionarse.
infrastructure/infrastructure/
infrastructure/odoo/
infrastructure/addons/


# ------------------------------------------------------------
# BASE DE DATOS вЂ” dumps y backups locales
# ------------------------------------------------------------
*.sql
*.dump
*.backup
backups/
db_backups/


# ------------------------------------------------------------
# EDITORES E IDEs
# ------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json    # SГ­ versionar extensiones recomendadas del equipo
!.vscode/settings.json.example

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Eclipse
.project
.classpath
.settings/


# ------------------------------------------------------------
# SISTEMA OPERATIVO
# ------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*


# ------------------------------------------------------------
# ODOO SCAFFOLD вЂ” archivos de demo que no se deben subir
# ------------------------------------------------------------
# Descomenta si usas `odoo scaffold` solo para referencia local:
# **/demo/
# **/tests/


# ------------------------------------------------------------
# CERTIFICADOS Y LLAVES
# ------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
ssl/


# ------------------------------------------------------------
# MISCELГЃNEOS
# ------------------------------------------------------------
*.tmp
*.bak
*.orig
*.rej
.cache/
tmp/
temp/
node_modules/          # Si algГєn mГіdulo usa npm/webpack
package-lock.json      # Generado automГЎticamente


# ============================================================
# QUГ‰ SГЌ DEBE ESTAR EN GIT (referencia)
# ============================================================
# вњ” odoo/addons/mi_modulo/__manifest__.py
# вњ” odoo/addons/mi_modulo/models/, views/, security/, data/
# вњ” odoo/addons/mi_modulo/migrations/  (scripts de migraciГіn propios)
# вњ” infra/docker-compose.yml
# вњ” infra/Dockerfile (si tienes imagen custom)
# вњ” infra/config/odoo.conf.example
# вњ” infra/docker-compose.override.yml.example
# вњ” .env.example  (plantilla sin valores reales)
# вњ” requirements.txt (dependencias Python extra de los addons)
# вњ” .vscode/extensions.json (recomendaciones del equipo)
# вњ” docs/**/*.md, docs/**/*.drawio
# вњ” README.md, infra/README.md, odoo/README.md, docs/README.md
# ============================================================
