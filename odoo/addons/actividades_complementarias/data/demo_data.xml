    <!--  El valor 1 corresponde a base.group_user en instalaciones base    -->
    <!-- ================================================================== -->

    <record id="user_jefe_sistemas" model="res.users">
        <field name="name">Dr. Carlos Mendoza</field>
        <field name="login">jefe.sistemas@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="user_jefe_electronica" model="res.users">
        <field name="name">Dra. Patricia Ruiz</field>
        <field name="login">jefe.electronica@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="user_comite_1" model="res.users">
        <field name="name">M.C. Roberto Sánchez</field>
        <field name="login">comite1@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="user_comite_2" model="res.users">
        <field name="name">Dra. Ana Flores</field>
        <field name="login">comite2@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="user_personal_sistemas" model="res.users">
        <field name="name">Ing. Luis Torres</field>
        <field name="login">personal.sistemas@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="user_responsable_1" model="res.users">
        <field name="name">Prof. María González</field>
        <field name="login">responsable1@ittech.edu.mx</field>
        <field name="password">Admin1234!</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ================================================================== -->
    <!--  ASIGNACIÓN DE GRUPOS DEL MÓDULO                                   -->
    <!-- ================================================================== -->

    <function model="res.groups" name="write">
        <value eval="[ref('actividades_complementarias.group_jefe_departamento')]"/>
        <value eval="{'users': [(4, ref('actividades_complementarias.user_jefe_sistemas')), (4, ref('actividades_complementarias.user_jefe_electronica'))]}"/>
    </function>

    <function model="res.groups" name="write">
        <value eval="[ref('actividades_complementarias.group_comite_academico')]"/>
        <value eval="{'users': [(4, ref('actividades_complementarias.user_comite_1')), (4, ref('actividades_complementarias.user_comite_2'))]}"/>
    </function>

    <function model="res.groups" name="write">
        <value eval="[ref('actividades_complementarias.group_personal_departamento')]"/>
        <value eval="{'users': [(4, ref('actividades_complementarias.user_personal_sistemas'))]}"/>
    </function>

    <!-- ================================================================== -->
    <!--  DEPARTAMENTOS                                                      -->
    <!-- ================================================================== -->

    <record id="depto_sistemas" model="actividad.departamento">
        <field name="name">Ingeniería en Sistemas Computacionales</field>
        <field name="jefe_id" ref="user_jefe_sistemas"/>
    </record>

    <record id="depto_electronica" model="actividad.departamento">
        <field name="name">Ingeniería Electrónica</field>
        <field name="jefe_id" ref="user_jefe_electronica"/>
    </record>

    <!-- ================================================================== -->
    <!--  PERMISOS DELEGADOS                                                -->
    <!-- ================================================================== -->

    <record id="permiso_personal_sistemas" model="actividad.empleado.permiso">
        <field name="user_id" ref="user_personal_sistemas"/>
        <field name="no_empleado">E-00142</field>
        <field name="carrera">ISC</field>
        <field name="departamento_id" ref="depto_sistemas"/>
        <field name="perm_modificar_actividades">True</field>
        <field name="perm_difundir_actividades">True</field>
        <field name="perm_asignar_alumnos">False</field>
        <field name="perm_enviar_catalogo">False</field>
    </record>

    <!-- ================================================================== -->
    <!--  ACTIVIDADES COMPLEMENTARIAS                                       -->
    <!-- ================================================================== -->

    <record id="act_futbol" model="actividad.complementaria">
        <field name="name">Fútbol Representativo</field>
        <field name="descripcion">Equipo representativo de fútbol del instituto. Entrenos y torneos regionales.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_deportiva"/>
        <field name="periodo">2025-A</field>
        <field name="jefe_departamento_id" ref="user_jefe_sistemas"/>
        <field name="responsable_actividad_id" ref="user_responsable_1"/>
        <field name="fecha_inicio">2026-03-20</field>
        <field name="fecha_fin">2026-06-20</field>
        <field name="cantidad_horas">60</field>
        <field name="creditos">4</field>
        <field name="horario">Martes y Jueves 16:00-18:00</field>
        <field name="cupo_min">10</field>
        <field name="cupo_max">22</field>
        <field name="estado_id" ref="actividades_complementarias.estado_aprobada"/>
    </record>

    <record id="act_robotica" model="actividad.complementaria">
        <field name="name">Club de Robótica</field>
        <field name="descripcion">Diseño y construcción de robots para competencias nacionales e internacionales.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_academica"/>
        <field name="periodo">2025-A</field>
        <field name="jefe_departamento_id" ref="user_jefe_sistemas"/>
        <field name="responsable_actividad_id" ref="user_responsable_1"/>
        <field name="fecha_inicio">2026-03-18</field>
        <field name="fecha_fin">2026-07-18</field>
        <field name="cantidad_horas">80</field>
        <field name="creditos">5</field>
        <field name="horario">Lunes y Miércoles 15:00-17:00</field>
        <field name="cupo_min">5</field>
        <field name="cupo_max">15</field>
        <field name="estado_id" ref="actividades_complementarias.estado_pendiente_inicio"/>
        <field name="en_catalogo">True</field>
    </record>

    <record id="act_teatro" model="actividad.complementaria">
        <field name="name">Teatro y Expresión Oral</field>
        <field name="descripcion">Taller de expresión oral y corporal orientado al desarrollo de habilidades de comunicación.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_cultural"/>
        <field name="periodo">2025-A</field>
        <field name="jefe_departamento_id" ref="user_jefe_electronica"/>
        <field name="responsable_actividad_id" ref="user_responsable_1"/>
        <field name="fecha_inicio">2026-02-20</field>
        <field name="fecha_fin">2026-04-30</field>
        <field name="cantidad_horas">40</field>
        <field name="creditos">3</field>
        <field name="cupo_min">8</field>
        <field name="cupo_max">25</field>
        <field name="estado_id" ref="actividades_complementarias.estado_en_curso"/>
    </record>

    <record id="act_ingles" model="actividad.complementaria">
        <field name="name">Curso de Inglés Técnico</field>
        <field name="descripcion">Curso intensivo de inglés enfocado en vocabulario técnico para ingeniería.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_academica"/>
        <field name="periodo">2024-B</field>
        <field name="jefe_departamento_id" ref="user_jefe_sistemas"/>
        <field name="responsable_actividad_id" ref="user_responsable_1"/>
        <field name="fecha_inicio">2025-10-01</field>
        <field name="fecha_fin">2026-01-31</field>
        <field name="cantidad_horas">60</field>
        <field name="creditos">4</field>
        <field name="cupo_min">10</field>
        <field name="cupo_max">30</field>
        <field name="estado_id" ref="actividades_complementarias.estado_finalizada"/>
    </record>

    <record id="act_hackathon" model="actividad.complementaria">
        <field name="name">Hackathon Institucional de IA</field>
        <field name="descripcion">Competencia de 48 horas para desarrollar soluciones con inteligencia artificial aplicada a problemáticas sociales.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_nueva"/>
        <field name="periodo">2025-A</field>
        <field name="jefe_departamento_id" ref="user_jefe_sistemas"/>
        <field name="fecha_inicio">2026-04-14</field>
        <field name="fecha_fin">2026-04-16</field>
        <field name="cantidad_horas">48</field>
        <field name="cupo_ilimitado">True</field>
        <field name="estado_id" ref="actividades_complementarias.estado_aprobada"/>
    </record>

    <record id="act_rechazada" model="actividad.complementaria">
        <field name="name">Torneo de Ajedrez Interinstitucional</field>
        <field name="descripcion">Torneo de ajedrez con participación de varios institutos de la región.</field>
        <field name="tipo_actividad_id" ref="actividades_complementarias.tipo_deportiva"/>
        <field name="periodo">2025-A</field>
        <field name="jefe_departamento_id" ref="user_jefe_electronica"/>
        <field name="fecha_inicio">2026-03-30</field>
        <field name="fecha_fin">2026-03-31</field>
        <field name="cantidad_horas">8</field>
        <field name="cupo_min">4</field>
        <field name="cupo_max">16</field>
        <field name="estado_id" ref="actividades_complementarias.estado_rechazada"/>
    </record>

    <!-- ================================================================== -->
    <!--  PROPUESTAS AL COMITÉ                                              -->
    <!-- ================================================================== -->

    <record id="propuesta_hackathon" model="actividad.propuesta">
        <field name="actividad_id" ref="act_hackathon"/>
        <field name="estado_solicitud_id" ref="actividades_complementarias.estado_solicitud_en_revision"/>
    </record>

    <record id="propuesta_robotica" model="actividad.propuesta">
        <field name="actividad_id" ref="act_robotica"/>
        <field name="estado_solicitud_id" ref="actividades_complementarias.estado_solicitud_aprobada"/>
    </record>

    <record id="propuesta_ajedrez" model="actividad.propuesta">
        <field name="actividad_id" ref="act_rechazada"/>
        <field name="estado_solicitud_id" ref="actividades_complementarias.estado_solicitud_rechazada"/>
        <field name="motivo_rechazo">La actividad no cumple con el mínimo de horas requeridas para otorgar créditos complementarios. Se solicita ampliar la duración o replantear el formato.</field>
    </record>

</data>
</odoo>
