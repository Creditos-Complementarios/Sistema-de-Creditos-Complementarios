<?xml version="1.0" encoding="utf-8"?>
<!--
    actividad_asistencia_views.xml
    ================================
    Vistas para el modelo actividad.asistencia (pase de lista).
    RA-02SC pasos 6–8 / RAE-01SC pasos 6–8.
-->
<odoo>
    <!-- ================================================================ -->
    <!-- VISTA LISTA (pase de lista tabular)                              -->
    <!-- ================================================================ -->
    <record id="view_actividad_asistencia_list" model="ir.ui.view">
        <field name="name">actividad.asistencia.list</field>
        <field name="model">actividad.asistencia</field>
        <field name="arch" type="xml">
            <list
                string="Pase de Lista"
                editable="bottom"
                decoration-success="presente"
                decoration-muted="not presente"
            >
                <field name="fecha"/>
                <field name="partner_id" string="Estudiante" readonly="True"/>
                <field name="presente" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- ACCIÓN                                                           -->
    <!-- ================================================================ -->
    <record id="action_actividad_asistencia" model="ir.actions.act_window">
        <field name="name">Pase de Lista</field>
        <field name="res_model">actividad.asistencia</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
