<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ─────────────────────────────────────────────────────────── -->
    <record id="view_tipo_actividad_list" model="ir.ui.view">
        <field name="name">actividad.tipo.list</field>
        <field name="model">actividad.tipo</field>
        <field name="arch" type="xml">
            <list string="Tipos de Actividad">
                <field name="name"/>
                <field name="es_predefinida"/>
            </list>
        </field>
    </record>

    <!-- ── Form ─────────────────────────────────────────────────────────── -->
    <record id="view_tipo_actividad_form" model="ir.ui.view">
        <field name="name">actividad.tipo.form</field>
        <field name="model">actividad.tipo</field>
        <field name="arch" type="xml">
            <form string="Tipo de Actividad">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="es_predefinida"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ───────────────────────────────────────────────────────── -->
    <record id="action_tipo_actividad" model="ir.actions.act_window">
        <field name="name">Tipos de Actividad</field>
        <field name="res_model">actividad.tipo</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
