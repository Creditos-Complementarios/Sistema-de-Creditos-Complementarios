<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         Wizard: Nueva Actividad Complementaria (JD-01SC)
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_wizard_nueva_actividad_form" model="ir.ui.view">
        <field name="name">actividad.wizard.nueva.form</field>
        <field name="model">actividad.wizard.nueva</field>
        <field name="arch" type="xml">
            <form string="Generar Actividad Complementaria">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Si selecciona un <strong>tipo predefinido</strong>, la actividad se registrará
                        directamente. Si es un <strong>tipo nuevo</strong>, se enviará al Comité Académico
                        para su revisión.
                    </div>
                    <group string="Información General">
                        <field name="name" placeholder="Nombre de la actividad (máx. 200 caracteres)"/>
                        <field name="tipo_actividad_id"/>
                        <field name="es_predefinida" invisible="1"/>
                        <field name="periodo" placeholder="Ej: 2025-A"/>
                    </group>
                    <group string="Responsable (solo actividades predefinidas)"
                           invisible="not es_predefinida">
                        <field name="responsable_actividad_id"/>
                        <field name="creditos"/>
                    </group>
                    <group string="Fechas y Duración">
                        <field name="fecha_inicio"/>
                        <field name="fecha_fin"/>
                        <field name="cantidad_horas"/>
                        <field name="horario" placeholder="Ej: Lunes 10:00-12:00"/>
                    </group>
                    <group string="Cupos">
                        <field name="cupo_ilimitado"/>
                        <field name="cupo_min" invisible="cupo_ilimitado"/>
                        <field name="cupo_max" invisible="cupo_ilimitado"/>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1" colspan="2"
                               placeholder="Descripción de la actividad (máx. 2000 caracteres)..."/>
                    </group>
                    <group string="Imagen">
                        <field name="ruta_imagen" widget="image" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirmar" string="Confirmar y Enviar"
                            type="object" class="btn-primary"/>
                    <button name="action_cancelar" string="Cancelar"
                            type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_nueva_actividad" model="ir.actions.act_window">
        <field name="name">Generar Actividad Complementaria</field>
        <field name="res_model">actividad.wizard.nueva</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         Wizard: Rechazar Propuesta
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_wizard_rechazar_form" model="ir.ui.view">
        <field name="name">actividad.wizard.rechazar.form</field>
        <field name="model">actividad.wizard.rechazar</field>
        <field name="arch" type="xml">
            <form string="Rechazar Propuesta">
                <sheet>
                    <group>
                        <field name="propuesta_id" readonly="1"/>
                        <field name="motivo_rechazo" required="1"
                               placeholder="Indique el motivo del rechazo..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirmar_rechazo" string="Confirmar Rechazo"
                            type="object" class="btn-danger"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_rechazar" model="ir.actions.act_window">
        <field name="name">Rechazar Propuesta</field>
        <field name="res_model">actividad.wizard.rechazar</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
