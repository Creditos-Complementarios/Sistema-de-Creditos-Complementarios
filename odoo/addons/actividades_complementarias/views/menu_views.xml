<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Menú raíz ─────────────────────────────────────────────────────── -->
    <menuitem id="menu_actividades_root"
              name="Actividades Complementarias"
              sequence="50"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_comite_academico,actividades_complementarias.group_personal_departamento_sistemas,actividades_complementarias.group_personal_departamento_electrica,actividades_complementarias.group_personal_departamento_biologia,actividades_complementarias.group_admin_actividades"
              web_icon="actividades_complementarias,static/description/icon.png"/>

    <!-- ── Jefe de Departamento ──────────────────────────────────────────── -->
    <menuitem id="menu_jefe_depto"
              name="Jefe de Departamento"
              parent="menu_actividades_root"
              sequence="10"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_mis_actividades"
              name="Mis Actividades"
              parent="menu_jefe_depto"
              action="action_actividad_complementaria"
              sequence="10"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_catalogo"
              name="Catálogo de Actividades"
              parent="menu_jefe_depto"
              action="action_actividad_catalogo"
              sequence="20"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_mis_propuestas"
              name="Mis Propuestas al Comité"
              parent="menu_jefe_depto"
              action="action_propuesta"
              sequence="30"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_gestion_personal"
              name="Gestión de Personal"
              parent="menu_jefe_depto"
              action="action_empleado_permiso"
              sequence="40"
              groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>

    <!-- ── Personal de Departamento ──────────────────────────────────────── -->
    <menuitem id="menu_personal_depto"
              name="Personal de Departamento"
              parent="menu_actividades_root"
              sequence="30"
              groups="actividades_complementarias.group_personal_departamento_sistemas,actividades_complementarias.group_personal_departamento_electrica,actividades_complementarias.group_personal_departamento_biologia,actividades_complementarias.group_admin_actividades"/>

    <!--
        Cada grupo de Personal tiene su propia acción con el domain del
        departamento correspondiente. Así "Mis Actividades" muestra solo las
        actividades de ese departamento, mientras que "Catálogo de Actividades"
        (acción compartida con domain en_catalogo=True) muestra todo el catálogo.
    -->
    <menuitem id="menu_personal_mis_actividades_sistemas"
              name="Mis Actividades"
              parent="menu_personal_depto"
              action="action_actividad_personal_sistemas"
              sequence="10"
              groups="actividades_complementarias.group_personal_departamento_sistemas"/>

    <menuitem id="menu_personal_mis_actividades_electrica"
              name="Mis Actividades"
              parent="menu_personal_depto"
              action="action_actividad_personal_electrica"
              sequence="11"
              groups="actividades_complementarias.group_personal_departamento_electrica"/>

    <menuitem id="menu_personal_mis_actividades_biologia"
              name="Mis Actividades"
              parent="menu_personal_depto"
              action="action_actividad_personal_biologia"
              sequence="12"
              groups="actividades_complementarias.group_personal_departamento_biologia"/>

    <!-- Admin también puede acceder desde el menú de Personal -->
    <menuitem id="menu_personal_mis_actividades_admin"
              name="Mis Actividades"
              parent="menu_personal_depto"
              action="action_actividad_complementaria"
              sequence="13"
              groups="actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_personal_catalogo"
              name="Catálogo de Actividades"
              parent="menu_personal_depto"
              action="action_actividad_catalogo"
              sequence="20"
              groups="actividades_complementarias.group_personal_departamento_sistemas,actividades_complementarias.group_personal_departamento_electrica,actividades_complementarias.group_personal_departamento_biologia,actividades_complementarias.group_admin_actividades"/>

    <!-- ── Comité Académico ───────────────────────────────────────────────── -->
    <menuitem id="menu_comite"
              name="Comité Académico"
              parent="menu_actividades_root"
              sequence="20"
              groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_propuestas_pendientes"
              name="Propuestas Pendientes"
              parent="menu_comite"
              action="action_propuesta_pendiente"
              sequence="10"
              groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_todas_propuestas"
              name="Historial de decisiones"
              parent="menu_comite"
              action="action_propuesta_todas"
              sequence="20"
              groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_catalogo_comite"
              name="Catálogo de Actividades"
              parent="menu_comite"
              action="action_actividad_catalogo"
              sequence="30"
              groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>

    <!-- ── Configuración ─────────────────────────────────────────────────── -->
    <menuitem id="menu_configuracion"
              name="Configuración"
              parent="menu_actividades_root"
              sequence="90"
              groups="actividades_complementarias.group_admin_actividades,actividades_complementarias.group_jefe_departamento"/>

    <menuitem id="menu_tipos_actividad"
              name="Tipos de Actividad"
              parent="menu_configuracion"
              action="action_tipo_actividad"
              sequence="10"
              groups="actividades_complementarias.group_admin_actividades"/>

    <menuitem id="menu_periodos"
              name="Periodos Escolares"
              parent="menu_configuracion"
              action="action_periodo"
              sequence="20"
              groups="actividades_complementarias.group_admin_actividades,actividades_complementarias.group_jefe_departamento"/>

    <!-- ── Admin: todas las actividades sin filtro ───────────────────────── -->
    <menuitem id="menu_admin_todas_actividades"
              name="Todas las Actividades"
              parent="menu_configuracion"
              action="action_actividad_todas"
              sequence="5"
              groups="actividades_complementarias.group_admin_actividades"/>

    <!-- ── Admin/Comité: catálogo unificado de predefinidas ─────────────── -->
    <menuitem id="menu_tipo_predefinida"
              name="Actividades Predefinidas"
              parent="menu_configuracion"
              action="actividades_complementarias.action_tipo_predefinida"
              sequence="12"
              groups="actividades_complementarias.group_admin_actividades,actividades_complementarias.group_comite_academico"/>

</odoo>