<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_periodo_list" model="ir.ui.view">
        <field name="name">actividad.periodo.list</field>
        <field name="model">sii.periodo</field>
        <field name="arch" type="xml">
            <list string="Periodos Escolares"
                  create="false" edit="false" delete="false" duplicate="false">
                <field name="clave_periodo"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
            </list>
        </field>
    </record>

    <record id="view_periodo_form" model="ir.ui.view">
        <field name="name">actividad.periodo.form</field>
        <field name="model">sii.periodo</field>
        <field name="arch" type="xml">
            <form string="Periodo Escolar" create="false" edit="false" delete="false" duplicate="false">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Los periodos escolares se sincronizan desde el SII y son de solo lectura.
                    </div>
                    <group>
                        <field name="clave_periodo" readonly="1"/>
                        <field name="fecha_inicio" readonly="1"/>
                        <field name="fecha_fin" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_periodo" model="ir.actions.act_window">
        <field name="name">Periodos Escolares</field>
        <field name="res_model">sii.periodo</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
