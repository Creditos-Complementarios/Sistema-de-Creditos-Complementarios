<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Search ───────────────────────────────────────────────────────── -->
    <record id="view_actividad_search" model="ir.ui.view">
        <field name="name">actividad.complementaria.search</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <search string="Buscar Actividades">
                <field name="name" string="Actividad"/>
                <field name="periodo"/>
                <field name="jefe_departamento_id"/>
                <filter name="filter_aprobada" string="Aprobadas" domain="[('estado_code','=','aprobada')]"/>
                <filter name="filter_en_curso" string="En Curso" domain="[('estado_code','=','en_curso')]"/>
                <filter name="filter_pendiente" string="Pendientes de Inicio" domain="[('estado_code','=','pendiente_inicio')]"/>
                <filter name="filter_finalizada" string="Finalizadas" domain="[('estado_code','=','finalizada')]"/>
                <filter name="filter_rechazada" string="Rechazadas" domain="[('estado_code','=','rechazada')]"/>
                <filter name="filter_catalogo" string="En Catálogo" domain="[('en_catalogo','=',True)]"/>
                <separator/>
                <filter name="group_estado" string="Por Estado" context="{'group_by':'estado_id'}"/>
                <filter name="group_tipo" string="Por Tipo" context="{'group_by':'tipo_actividad_id'}"/>
                <filter name="group_periodo" string="Por Periodo" context="{'group_by':'periodo'}"/>
            </search>
        </field>
    </record>

    <!-- ── Search (catálogo) ─────────────────────────────────────────────── -->
    <record id="view_actividad_Catalogo_search" model="ir.ui.view">
        <field name="name">actividad.complementaria.search</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <search string="Buscar Actividades">
                <field name="name" string="Actividad"/>
                <field name="periodo"/>
                <field name="jefe_departamento_id"/>
                <filter name="group_tipo" string="Por Tipo" context="{'group_by':'tipo_actividad_id'}"/>
                <filter name="group_periodo" string="Por Periodo" context="{'group_by':'periodo'}"/>
            </search>
        </field>
    </record>

    <!-- ── List ─────────────────────────────────────────────────────────── -->
    <record id="view_actividad_list" model="ir.ui.view">
        <field name="name">actividad.complementaria.list</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <list string="Actividades Complementarias">
                <field name="name"/>
                <field name="tipo_actividad_id"/>
                <field name="periodo"/>
                <field name="fecha_inicio" string="Fecha Inicio" width="100px"/>
                <field name="fecha_fin" string="Fecha Fin" width="100px"/>
                <field name="estado_id" widget="badge"
                    decoration-warning="estado_code == 'en_revision'"
                    decoration-success="estado_code in ['aprobada', 'en_curso']"
                    decoration-info="estado_code == 'pendiente_inicio'"
                    decoration-danger="estado_code == 'rechazada'"
                    decoration-muted="estado_code == 'finalizada'"/>
                <field name="en_catalogo" widget="boolean" readonly="1"
                    column_invisible="context.get('hide_catalogo', False)"/>
                <field name="alumno_count" string="Alumnos"/>
                <field name="estado_code" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form ─────────────────────────────────────────────────────────── -->
    <record id="view_actividad_form" model="ir.ui.view">
        <field name="name">actividad.complementaria.form</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <form string="Actividad Complementaria">
                <header>
                    <button name="action_abrir_confirmacion_comite" string="Enviar al Comité Académico"
                        type="object" class="btn-warning"
                        invisible="tiene_propuesta_activa or tipo_actividad_predefinida or actividad_predefinida or estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada']"
                        groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                    <!-- Botón para actividades predefinidas (sin pasar por el Comité) -->
                    <button name="action_abrir_confirmacion_catalogo" string="Enviar al Catálogo"
                        type="object" class="btn-warning"
                        invisible="not actividad_predefinida or en_catalogo or estado_code in ['rechazada','finalizada']"
                        groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                    <!-- Statusbar: solo En Revisión -->
                    <field name="estado_barra" widget="statusbar"
                        statusbar_visible="en_revision"
                        invisible="estado_code != 'en_revision'"
                        readonly="1"/>
                    <!-- Statusbar: solo Rechazada -->
                    <field name="estado_barra" widget="statusbar"
                        statusbar_visible="rechazada"
                        invisible="estado_code != 'rechazada'"
                        readonly="1"/>
                    <!-- Statusbar: flujo Aprobada → Finalizada -->
                    <field name="estado_barra" widget="statusbar"
                        statusbar_visible="aprobada,pendiente_inicio,en_curso,finalizada"
                        invisible="estado_code not in ['aprobada','pendiente_inicio','en_curso','finalizada']"
                        readonly="1"/>
                    <button name="action_enviar_catalogo" string="Enviar al Catálogo"
                            type="object" class="btn-primary"
                            invisible="estado_code not in ['aprobada','pendiente_inicio'] or en_catalogo"
                            groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                    <button name="action_firmar_constancias" string="Firmar Constancias"
                            type="object" class="btn-primary"
                            invisible="estado_code != 'finalizada' or constancias_firmadas"
                            groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                </header>
                <sheet>
                    <field name="tiene_propuesta_activa" invisible="1"/>
                    <field name="tipo_actividad_predefinida" invisible="1"/>
                    <field name="tipo_es_nueva" invisible="1"/>
                    <field name="dominio_responsable" invisible="1"/>
                    <field name="dominio_alumnos" invisible="1"/>
                    <!-- Flags de permisos de edición (calculados por rol y estado) -->
                    <field name="permisos_actividad_finalizada" invisible="1"/>
                    <field name="permisos_actividad_en_curso" invisible="1"/>

                    <!--
                        Banner informativo de solo lectura.
                        Aparece cuando el formulario está bloqueado para el usuario actual.
                    -->
                    <div class="alert alert-warning mb-2"
                         invisible="not permisos_actividad_finalizada and not permisos_actividad_pendiente_inicio
                         and not permisos_actividad_en_curso"
                         role="alert">
                        <span invisible="estado_code == 'finalizada'">
                            <i class="fa fa-lock me-1"/>
                            <b invisible="permisos_actividad_en_curso">
                                Esta actividad no puede modificarse en su estado actual.
                            </b>
                            <b invisible="not permisos_actividad_pendiente_inicio">
                                Solo puede modificar los campos <i>Responsable de Actividad</i>, <i>Fecha de Inicio</i>, <i>Fecha de Finalización</i>, <i>Alumnos</i> y
                                <i>Horario por Día</i> en este estado.
                            </b>
                            <b invisible="not permisos_actividad_en_curso">
                                Solo puede modificar el campo <i>Responsable de Actividad</i> en este estado.
                            </b>
                        </span>
                        <span invisible="estado_code != 'finalizada'">
                            <i class="fa fa-lock me-1"/>
                            <b>Esta actividad está finalizada y no puede ser modificada.</b>
                        </span>
                    </div>

                    <field name="responsable_bloqueado" invisible="1"/>
                    <field name="horas_maximas" invisible="1"/>
                    <field name="ruta_imagen" widget="image" class="oe_avatar"
                           readonly="estado_code in ['aprobada','en_curso','finalizada','en_revision']"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la actividad..."
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                        </h1>
                    </div>
                    <group col="1">
                        <group string="Información General">
                            <field name="tipo_actividad_id"
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                            <field name="actividad_predefinida"
                                   invisible="tipo_es_nueva"
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"
                                   options="{'no_create': True, 'no_quick_create': True}"
                                   help="Seleccione si la actividad es predefinida (aprobación automática). Las actividades aprobadas por el Comité también aparecen aquí."/>
                            <field name="periodo"
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                            <field name="jefe_departamento_id" readonly="1"/>
                            <field name="departamento_id" readonly="1"/>
                            <field name="responsable_actividad_id"
                                   domain="dominio_responsable"
                                   options="{'no_create': True, 'no_quick_create': True}"
                                   invisible="not actividad_predefinida and estado_code not in ['aprobada','pendiente_inicio','en_curso','finalizada','rechazada']"
                                   readonly="estado_code in ['en_revision','finalizada']"/>
                            <button name="action_abrir_wizard_responsable"
                                    string="Asignar Responsable"
                                    type="object"
                                    class="btn btn-primary btn-sm"
                                    invisible="responsable_bloqueado or responsable_actividad_id or estado_code not in ['aprobada','pendiente_inicio']"
                                    groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                        </group>
                        <group string="Fechas y Duración">
                            <field name="fecha_inicio"
                                   readonly="estado_code in ['en_curso','finalizada','en_revision']"/>
                            <field name="fecha_fin"
                                   readonly="estado_code in ['en_curso','finalizada','en_revision']"/>
                            <field name="cantidad_horas"
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                            <field name="creditos"
                                   readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                            <field name="horario"
                                   placeholder="Ej:&#10;Lunes 10:00-12:00&#10;Miércoles 10:00-12:00"
                                   readonly="estado_code in ['en_curso','finalizada','en_revision']"
                                   help="Un horario por línea con el formato: Día HH:MM-HH:MM"/>
                            <div class="alert alert-warning mb-0" role="alert"
                                 invisible="horario_valido or not horario">
                                <strong>&#9888; Formato incorrecto.</strong>
                                Use una línea por horario:
                                <code>Día HH:MM-HH:MM</code><br/>
                                Ejemplo: <code>Lunes 10:00-12:00</code>
                            </div>
                            <field name="horario_sanitizado"
                                   string="Vista Normalizada"
                                   readonly="1"
                                   invisible="not horario_valido or not horario"
                                   help="Versión normalizada del horario ingresado."/>
                        </group>
                    </group>
                    <!-- Cupos -->
                    <group string="Cupos">
                        <field name="cupo_ilimitado"
                               readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                        <field name="cupo_min" invisible="cupo_ilimitado"
                               readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                        <field name="cupo_max" invisible="cupo_ilimitado"
                               readonly="estado_code in ['aprobada','pendiente_inicio','en_curso','finalizada','en_revision']"/>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1" colspan="2"
                               placeholder="Descripción de la actividad (máximo 2000 caracteres)..."
                               readonly="estado_code in ['aprobada','en_curso','finalizada','en_revision']"/>
                    </group>
                    <!-- Pestaña de alumnos: visible cuando aprobada o más avanzada -->
                    <notebook invisible="estado_code not in ['aprobada','pendiente_inicio','en_curso','finalizada'] and not en_catalogo">
                        <page string="Alumnos Asignados" name="alumnos">
                            <button name="action_abrir_wizard_eliminar_alumnos"
                                string="Eliminar alumnos"
                                type="object"
                                class="btn btn-danger btn-sm mb-2"
                                invisible="estado_code in ['finalizada'] or not alumno_ids"
                                groups="actividades_complementarias.group_jefe_departamento,actividades_complementarias.group_admin_actividades"/>
                            <field name="alumno_ids"
                                   domain="dominio_alumnos"
                                   readonly="estado_code in ['finalizada']"
                                   options="{'no_create': True, 'no_quick_create': True}">
                                <list>
                                    <field name="name"/>
                                    <field name="login" string="Correo / Usuario"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Kanban ────────────────────────────────────────────────────────── -->
    <record id="view_actividad_kanban" model="ir.ui.view">
        <field name="name">actividad.complementaria.kanban</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado_id" class="o_kanban_small_column">
                <field name="name"/>
                <field name="tipo_actividad_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado_code"/>
                <field name="alumno_count"/>
                <field name="en_catalogo"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="tipo_actividad_id"/>
                            </div>
                            <div>
                                <i class="fa fa-calendar"/> <field name="fecha_inicio"/> — <field name="fecha_fin"/>
                            </div>
                            <div class="mt-2">
                                <span class="badge bg-info" t-if="record.en_catalogo.raw_value">En Catálogo</span>
                                <span><i class="fa fa-users"/> <field name="alumno_count"/> alumnos</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista lista para Mis Actividades (JD): permite crear -->
    <record id="view_actividad_list_jefe" model="ir.ui.view">
        <field name="name">actividad.complementaria.list.jefe</field>
        <field name="model">actividad.complementaria</field>
        <field name="inherit_id" ref="view_actividad_list"/>
        <field name="arch" type="xml">
            <list position="attributes">
                <attribute name="create">true</attribute>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         Vista heredada — secciones exclusivas de RA y RAE
         Añade al formulario base:
           · Botones de gestión operativa (evidencias, constancias, firma RA)
           · Pestaña "Evaluación de Estudiantes" con inscripcion_ids
           · Pestaña "Pase de Lista" con asistencia_ids
         Visible para RA y RAE; el JD/Admin ve las mismas pestañas pero
         vacías si no gestionan inscripciones directamente.
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_actividad_form_ra_rae" model="ir.ui.view">
        <field name="name">actividad.complementaria.form.ra_rae</field>
        <field name="model">actividad.complementaria</field>
        <field name="inherit_id" ref="view_actividad_form"/>
        <field name="arch" type="xml">

            <!-- ── Botones de gestión operativa en header ─────────────── -->
            <!--
                Se insertan después del último botón existente (action_firmar_constancias)
                para respetar el orden visual de la barra de estado.
            -->
            <xpath expr="//header/button[@name='action_firmar_constancias']" position="after">

                <!--
                    RA-02SC / RAE-01SC: habilitar / deshabilitar evidencias.
                    Visible para RA y RAE mientras la actividad esté activa.
                -->
                <button name="action_toggle_evidence"
                        type="object"
                        class="btn-secondary"
                        invisible="estado_code not in ['pendiente_inicio','en_curso']"
                        groups="actividades_complementarias.group_responsable_actividad,
                                actividades_complementarias.group_responsable_actividad_extraescolar">
                    <span invisible="evidence_enabled">Habilitar Evidencias</span>
                    <span invisible="not evidence_enabled">Deshabilitar Evidencias</span>
                </button>

                <!--
                    RA-02SC / RAE-01SC pasos 9-10: generar constancias.
                    Solo cuando la actividad está finalizada y aún no se generaron.
                -->
                <button name="action_generate_certificates"
                        string="Generar Constancias"
                        type="object"
                        class="btn-primary"
                        invisible="estado_code != 'finalizada' or certificates_generated"
                        groups="actividades_complementarias.group_responsable_actividad,
                                actividades_complementarias.group_responsable_actividad_extraescolar"/>

                <!--
                    RA-02SC paso 13: firmar constancias (solo RA, no RAE).
                    Permanece desactivado (invisible) hasta que se generan las constancias.
                -->
                <button name="action_firmar_constancias_responsable"
                        string="Firmar Constancias (Responsable)"
                        type="object"
                        class="btn-success"
                        invisible="not certificates_generated or responsable_firmo"
                        groups="actividades_complementarias.group_responsable_actividad"/>

            </xpath>

            <!-- ── Campo de control de evidencias (invisible, usado en botón) -->
            <xpath expr="//field[@name='responsable_bloqueado']" position="after">
                <field name="evidence_enabled" invisible="1"/>
                <field name="certificates_generated" invisible="1"/>
                <field name="responsable_firmo" invisible="1"/>
            </xpath>

            <!-- ── Pestañas de evaluación y asistencia ────────────────── -->
            <!--
                Se agregan dentro del notebook existente.
                Solo visibles cuando la actividad está en un estado operativo.
            -->
            <xpath expr="//notebook" position="inside">

                <!--
                    Pestaña de evaluación: lista de inscripciones con nivel de
                    desempeño por alumno (RA-02SC pasos 4-9 / RAE-01SC pasos 4-9).
                -->
                <page string="Evaluación de Estudiantes"
                      name="inscripciones"
                      invisible="estado_code not in ['pendiente_inicio','en_curso','finalizada']"
                      groups="actividades_complementarias.group_responsable_actividad,
                              actividades_complementarias.group_responsable_actividad_extraescolar,
                              actividades_complementarias.group_jefe_departamento,
                              actividades_complementarias.group_admin_actividades">
                    <field name="inscripcion_ids">
                        <list editable="bottom"
                              decoration-success="certificate_generated"
                              decoration-muted="performance_level == '0'">
                            <field name="partner_id" string="Estudiante"/>
                            <field name="performance_level"
                                   widget="badge"
                                   readonly="estado_id != 'finalizada'"
                                   decoration-danger="performance_level == '0'"
                                   decoration-warning="performance_level == '1'"
                                   decoration-info="performance_level == '2'"
                                   decoration-success="performance_level in ('3','4')"/>
                            <field name="observations"
                                   readonly="estado_id != 'finalizada'"
                                   optional="show"/>
                            <field name="certificate_generated" readonly="1" optional="show"/>
                            <field name="certificate_signed" readonly="1" optional="show"/>
                            <!--
                                Campo auxiliar para el readonly condicional de performance_level.
                                Se expone como invisible para que el ORM lo incluya en el contexto.
                            -->
                            <field name="estado_id" column_invisible="1"/>
                        </list>
                    </field>
                </page>

                <!--
                    Pestaña de pase de lista: asistencia por fecha
                    (RA-02SC pasos 6-8 / RAE-01SC pasos 6-8).
                    Solo disponible mientras la actividad está en curso.
                -->
                <page string="Pase de Lista"
                      name="asistencia"
                      invisible="estado_code not in ['en_curso','finalizada']"
                      groups="actividades_complementarias.group_responsable_actividad,
                              actividades_complementarias.group_responsable_actividad_extraescolar,
                              actividades_complementarias.group_jefe_departamento,
                              actividades_complementarias.group_admin_actividades">
                    <field name="asistencia_ids"
                           readonly="estado_code == 'finalizada'">
                        <list editable="bottom"
                              decoration-success="presente"
                              decoration-muted="not presente">
                            <field name="fecha"/>
                            <field name="inscripcion_id" string="Inscripción"/>
                            <field name="partner_id" string="Estudiante" readonly="1"/>
                            <field name="presente" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

    <!-- ── Actions ──────────────────────────────────────────────────────── -->

    <!--
        Mis Actividades (JD / Admin): domain filtra por jefe_departamento_id.
        La record rule de JD es write-only (perm_read=False) y no interfiere
        con la lectura del Catálogo ni con otras vistas.
    -->
    <record id="action_actividad_complementaria" model="ir.actions.act_window">
        <field name="name">Mis Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('jefe_departamento_id', '=', uid)]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="views" eval="[(ref('view_actividad_list_jefe'), 'list'), (ref('view_actividad_kanban'), 'kanban'), (ref('view_actividad_form'), 'form')]"/>
    </record>

    <!-- Admin: ve todas las actividades sin filtro -->
    <record id="action_actividad_todas" model="ir.actions.act_window">
        <field name="name">Todas las Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_actividad_search"/>
    </record>

    <!-- Personal de Departamento — una acción por departamento -->
    <record id="action_actividad_personal_sistemas" model="ir.actions.act_window">
        <field name="name">Mis Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('departamento_id.name', 'ilike', 'sistem')]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="views" eval="[(ref('view_actividad_list'), 'list'), (ref('view_actividad_kanban'), 'kanban'), (ref('view_actividad_form'), 'form')]"/>
    </record>

    <record id="action_actividad_personal_electrica" model="ir.actions.act_window">
        <field name="name">Mis Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('departamento_id.name', 'ilike', 'electr')]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="views" eval="[(ref('view_actividad_list'), 'list'), (ref('view_actividad_kanban'), 'kanban'), (ref('view_actividad_form'), 'form')]"/>
    </record>

    <record id="action_actividad_personal_biologia" model="ir.actions.act_window">
        <field name="name">Mis Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('departamento_id.name', 'ilike', 'biol')]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="views" eval="[(ref('view_actividad_list'), 'list'), (ref('view_actividad_kanban'), 'kanban'), (ref('view_actividad_form'), 'form')]"/>
    </record>

    <!-- Catálogo global -->
    <record id="action_actividad_catalogo" model="ir.actions.act_window">
        <field name="name">Catálogo General de Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('en_catalogo', '=', True)]</field>
        <field name="search_view_id" ref="view_actividad_Catalogo_search"/>
        <field name="context">{'hide_catalogo': True}</field>
    </record>

    <!--
        RA-02SC: Mis Actividades Asignadas (Responsable de Actividad).
        Filtra por responsable_actividad_id = usuario actual.
        La record rule complementa el filtro bloqueando el acceso ORM a otras actividades.
    -->
    <record id="action_actividad_responsable" model="ir.actions.act_window">
        <field name="name">Mis Actividades Asignadas</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('responsable_actividad_id', '=', uid)]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="context">{'search_default_filter_pendiente': 0}</field>
    </record>

    <!--
        RAE-01SC: Mis Actividades Asignadas (Responsable de Actividad Extraescolar).
        Filtra por responsable_extraescolar_id = usuario actual.
        La record rule impide lectura de cualquier otra actividad a nivel ORM.
    -->
    <record id="action_actividad_extraescolar" model="ir.actions.act_window">
        <field name="name">Mis Actividades Asignadas</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('responsable_extraescolar_id', '=', uid)]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
        <field name="context">{'search_default_filter_pendiente': 0}</field>
    </record>

</odoo>
