<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Search ───────────────────────────────────────────────────────── -->
    <record id="view_actividad_search" model="ir.ui.view">
        <field name="name">actividad.complementaria.search</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <search string="Buscar Actividades">
                <field name="name" string="Actividad"/>
                <field name="periodo"/>
                <field name="jefe_departamento_id"/>
                <filter name="filter_aprobada" string="Aprobadas" domain="[('estado_code','=','aprobada')]"/>
                <filter name="filter_en_curso" string="En Curso" domain="[('estado_code','=','en_curso')]"/>
                <filter name="filter_pendiente" string="Pendientes de Inicio" domain="[('estado_code','=','pendiente_inicio')]"/>
                <filter name="filter_finalizada" string="Finalizadas" domain="[('estado_code','=','finalizada')]"/>
                <filter name="filter_rechazada" string="Rechazadas" domain="[('estado_code','=','rechazada')]"/>
                <filter name="filter_catalogo" string="En Catálogo" domain="[('en_catalogo','=',True)]"/>
                <separator/>
                <filter name="group_estado" string="Por Estado" context="{'group_by':'estado_id'}"/>
                <filter name="group_tipo" string="Por Tipo" context="{'group_by':'tipo_actividad_id'}"/>
                <filter name="group_periodo" string="Por Periodo" context="{'group_by':'periodo'}"/>
            </search>
        </field>
    </record>

    <!-- ── List ─────────────────────────────────────────────────────────── -->
    <record id="view_actividad_list" model="ir.ui.view">
        <field name="name">actividad.complementaria.list</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <list string="Actividades Complementarias" decoration-success="estado_code=='en_curso'"
                  decoration-info="estado_code=='pendiente_inicio'"
                  decoration-muted="estado_code=='finalizada'"
                  decoration-danger="estado_code=='rechazada'">
                <field name="name"/>
                <field name="tipo_actividad_id"/>
                <field name="periodo"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado_id"/>
                <field name="en_catalogo" widget="boolean_toggle"/>
                <field name="alumno_count" string="Alumnos"/>
                <field name="estado_code" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form ─────────────────────────────────────────────────────────── -->
    <record id="view_actividad_form" model="ir.ui.view">
        <field name="name">actividad.complementaria.form</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <form string="Actividad Complementaria">
                <header>
                    <field name="estado_id" widget="statusbar"
                           statusbar_visible="aprobada,pendiente_inicio,en_curso,finalizada"/>
                    <button name="action_enviar_catalogo" string="Enviar al Catálogo"
                            type="object" class="btn-primary"
                            invisible="estado_code not in ['aprobada','pendiente_inicio'] or en_catalogo"/>
                    <button name="action_firmar_constancias" string="Firmar Constancias"
                            type="object" class="btn-primary"
                            invisible="estado_code != 'finalizada' or constancias_firmadas"
                            groups="actividades_complementarias.group_jefe_departamento"/>
                </header>
                <sheet>
                    <field name="ruta_imagen" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la actividad..."/></h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="tipo_actividad_id"/>
                            <field name="periodo"/>
                            <field name="jefe_departamento_id" readonly="1"/>
                            <field name="departamento_id" readonly="1"/>
                            <field name="responsable_actividad_id"/>
                        </group>
                        <group string="Fechas y Duración">
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                            <field name="cantidad_horas"/>
                            <field name="creditos"/>
                            <field name="horario" placeholder="Ej: Lunes 10:00-12:00, Miércoles 10:00-12:00"/>
                        </group>
                    </group>
                    <group string="Cupos">
                        <field name="cupo_ilimitado"/>
                        <field name="cupo_min" invisible="cupo_ilimitado"/>
                        <field name="cupo_max" invisible="cupo_ilimitado"/>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1" colspan="2"
                               placeholder="Descripción de la actividad (máximo 2000 caracteres)..."/>
                    </group>
                    <notebook>
                        <page string="Alumnos Asignados" name="alumnos"
                              invisible="estado_code in ['aprobada','rechazada'] or en_catalogo">
                            <field name="alumno_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Kanban ────────────────────────────────────────────────────────── -->
    <record id="view_actividad_kanban" model="ir.ui.view">
        <field name="name">actividad.complementaria.kanban</field>
        <field name="model">actividad.complementaria</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado_id" class="o_kanban_small_column">
                <field name="name"/>
                <field name="tipo_actividad_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado_code"/>
                <field name="alumno_count"/>
                <field name="en_catalogo"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="tipo_actividad_id"/>
                            </div>
                            <div>
                                <i class="fa fa-calendar"/> <field name="fecha_inicio"/> — <field name="fecha_fin"/>
                            </div>
                            <div class="mt-2">
                                <span class="badge bg-info" t-if="record.en_catalogo.raw_value">En Catálogo</span>
                                <span><i class="fa fa-users"/> <field name="alumno_count"/> alumnos</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Actions ──────────────────────────────────────────────────────── -->
    <record id="action_actividad_complementaria" model="ir.actions.act_window">
        <field name="name">Actividades Complementarias</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_actividad_search"/>
    </record>

    <record id="action_actividad_catalogo" model="ir.actions.act_window">
        <field name="name">Catálogo de Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('en_catalogo', '=', True)]</field>
        <field name="search_view_id" ref="view_actividad_search"/>
    </record>

</odoo>
