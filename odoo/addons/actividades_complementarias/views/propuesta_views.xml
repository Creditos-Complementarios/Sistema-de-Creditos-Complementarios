<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_propuesta_list" model="ir.ui.view">
        <field name="name">actividad.propuesta.list</field>
        <field name="model">actividad.propuesta</field>
        <field name="arch" type="xml">
            <list string="Propuestas al Comite Academico" create="0"
                  decoration-warning="estado_code=='en_revision'"
                  decoration-success="estado_code=='aprobada'"
                  decoration-danger="estado_code=='rechazada'">
                <field name="encabezado" string="Actividad"/>
                <field name="actividad_tipo" string="Tipo"/>
                <field name="actividad_jefe" string="Jefe de Departamento"/>
                <field name="actividad_departamento" string="Departamento"/>
                <field name="actividad_periodo" string="Periodo"/>
                <field name="fecha" string="Enviada"/>
                <field name="fecha_limite_revision" string="Limite"/>
                <field name="estado_solicitud_id" string="Estado"/>
                <field name="estado_code" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_propuesta_form" model="ir.ui.view">
        <field name="name">actividad.propuesta.form</field>
        <field name="model">actividad.propuesta</field>
        <field name="arch" type="xml">
            <form string="Propuesta al Comite Academico">
                <header>
                    <button name="action_abrir_wizard_aprobacion" string="Aprobar"
                            type="object" class="btn-success"
                            invisible="estado_code != 'en_revision'"
                            groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>
                    <button name="action_abrir_wizard_rechazo" string="Rechazar"
                            type="object" class="btn-danger"
                            invisible="estado_code != 'en_revision'"
                            groups="actividades_complementarias.group_comite_academico,actividades_complementarias.group_admin_actividades"/>
                    <field name="estado_solicitud_id" widget="statusbar"
                           statusbar_visible="en_revision,aprobada,rechazada"/>
                </header>
                <sheet>
                    <!-- Boton Regresar -->
                    <div class="o_form_buttons_view mb-3">
                        <button string="Regresar" type="object"
                                name="action_regresar_lista"
                                class="btn btn-secondary"/>
                    </div>
                    <group>
                        <group string="Datos de la Propuesta">
                            <field name="actividad_id" readonly="1"/>
                            <field name="fecha" readonly="1"/>
                            <field name="fecha_limite_revision" readonly="1"/>
                            <field name="estado_solicitud_id" readonly="1"/>
                        </group>
                        <group string="Resolucion">
                            <field name="motivo_rechazo" invisible="estado_code != 'rechazada'" readonly="1"/>
                        </group>
                    </group>
                    <group string="Detalle de la Actividad Propuesta" colspan="2">
                        <group>
                            <field name="actividad_nombre" readonly="1" string="Nombre"/>
                            <field name="actividad_tipo" readonly="1" string="Tipo"/>
                            <field name="actividad_jefe" readonly="1" string="Jefe de Departamento"/>
                            <field name="actividad_departamento" readonly="1" string="Departamento"/>
                            <field name="actividad_periodo" readonly="1" string="Periodo"/>
                        </group>
                        <group>
                            <field name="actividad_fecha_inicio" readonly="1" string="Fecha de Inicio"/>
                            <field name="actividad_fecha_fin" readonly="1" string="Fecha de Fin"/>
                            <field name="actividad_horas" readonly="1" string="Horas"/>
                            <field name="actividad_creditos" readonly="1" string="Creditos"/>
                            <field name="actividad_cupo" readonly="1" string="Cupo"/>
                        </group>
                        <field name="actividad_descripcion" readonly="1" string="Descripcion" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_propuesta" model="ir.actions.act_window">
        <field name="name">Mis Propuestas al Comite</field>
        <field name="res_model">actividad.propuesta</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('actividad_id.jefe_departamento_id', '=', uid)]</field>
        <field name="context">{"origen_propuesta": "mis_propuestas"}</field>
    </record>

    <record id="action_propuesta_pendiente" model="ir.actions.act_window">
        <field name="name">Propuestas Pendientes</field>
        <field name="res_model">actividad.propuesta</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('estado_code','=','en_revision')]</field>
        <field name="context">{"origen_propuesta": "pendientes"}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay ninguna propuesta pendiente</p>
            <p>Las propuestas enviadas por los Jefes de Departamento aparecerán aquí.</p>
        </field>
    </record>

    <record id="action_propuesta_todas" model="ir.actions.act_window">
        <field name="name">Todas las Propuestas</field>
        <field name="res_model">actividad.propuesta</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"origen_propuesta": "todas"}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay propuestas registradas</p>
            <p>Aún no se han enviado propuestas al Comité Académico.</p>
        </field>
    </record>

    <record id="action_catalogo_comite" model="ir.actions.act_window">
        <field name="name">Catálogo de Actividades</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('estado_code', 'in', ['aprobada','pendiente_inicio','en_curso','finalizada'])]</field>
        <field name="context">{'search_default_filter_catalogo': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay actividades en el catálogo</p>
            <p>Las actividades aprobadas por el Comité aparecerán aquí.</p>
        </field>
    </record>

    <!-- Acción para cambiar el texto de propuestas pendientes -->
    <record id="action_propuesta_pendiente" model="ir.actions.act_window">
        <field name="name">Propuestas Pendientes</field>
        <field name="res_model">actividad.propuesta</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('estado_code','=','en_revision')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay ninguna propuesta pendiente
            </p>
            <p>Las propuestas enviadas por los Jefes de Departamento aparecerán aquí.</p>
        </field>
    </record>
    
    <!-- Acción para cambiar el texto de todas las propuestas -->
    <record id="action_propuesta_todas" model="ir.actions.act_window">
        <field name="name">Todas las Propuestas</field>
        <field name="res_model">actividad.propuesta</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay propuestas registradas
            </p>
            <p>Aún no se han enviado propuestas al Comité Académico.</p>
        </field>
    </record>
   <!-- Acción para cambiar el texto de catalogo de actividades -->
   <record id="action_catalogo_comite" model="ir.actions.act_window">
    <field name="name">Catálogo de Actividades</field>
    <field name="res_model">actividad.complementaria</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="domain">[('en_catalogo', '=', True)]</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No hay actividades en el catálogo
        </p>
        <p>Las actividades enviadas al catálogo por los Jefes de Departamento aparecerán aquí.</p>
    </field>
</record>

    <!-- Acción para cambiar el texto de catalogo de actividades -->
    <record id="action_catalogo_comite" model="ir.actions.act_window">
        <field name="name">Catálogo de Actividades Aprobadas</field>
        <field name="res_model">actividad.complementaria</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('estado_code', 'in', ['aprobada','pendiente_inicio','en_curso','finalizada'])]</field>
        <field name="context">{'search_default_filter_catalogo': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay actividades en el catálogo
            </p>
            <p>Las actividades aprobadas por el Comité aparecerán aquí.</p>
        </field>
    </record>
</odoo>
