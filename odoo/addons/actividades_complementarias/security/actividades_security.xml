<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_admin_actividades" model="res.groups">
        <field name="name">Administrador de Actividades Complementarias</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_jefe_departamento" model="res.groups">
        <field name="name">Jefe de Departamento</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_comite_academico" model="res.groups">
        <field name="name">Comité Académico</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_responsable_actividad" model="res.groups">
        <field name="name">Responsable de Actividad</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Personal de Departamento dividido por rama -->
    <record id="group_personal_departamento_sistemas" model="res.groups">
        <field name="name">Personal de Departamento de Sistemas</field>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('actividades_complementarias.group_responsable_actividad'))
        ]"/>
    </record>

    <record id="group_personal_departamento_electrica" model="res.groups">
        <field name="name">Personal de Departamento de Eléctrica</field>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('actividades_complementarias.group_responsable_actividad'))
        ]"/>
    </record>

    <record id="group_personal_departamento_biologia" model="res.groups">
        <field name="name">Personal de Departamento de Biología</field>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('actividades_complementarias.group_responsable_actividad'))
        ]"/>
    </record>

    <!--
        Departamento de Extraescolares (DE-01SC, DE-02SC, DE-03SC).
        Grupo stub — añadir a DEPT_MAP en empleado_permiso.py al implementar este actor.
    -->
    <record id="group_personal_departamento_extraescolar" model="res.groups">
        <field name="name">Personal de Departamento Extraescolar</field>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('actividades_complementarias.group_responsable_actividad'))
        ]"/>
    </record>

    <record id="group_alumno" model="res.groups">
        <field name="name">Alumno</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!--
        Responsable de Actividad Extraescolar (RAE-01SC).
        Grupo distinto al RA: no hereda sus permisos.
        Solo gestiona (sin crear ni eliminar) actividades que le son asignadas
        explícitamente mediante el campo responsable_extraescolar_id.
    -->
    <record id="group_responsable_actividad_extraescolar" model="res.groups">
        <field name="name">Responsable de Actividad Extraescolar</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">
            Puede gestionar asistencia, evidencias y evaluaciones de las
            actividades donde está asignado como responsable extraescolar.
            No puede crear, aprobar ni eliminar actividades.
        </field>
    </record>

    <!--
        Servicios Escolares (SE-01SC..SE-04SC).
        Grupo stub — añadir rows en ir.model.access.csv al implementar este actor.
    -->
    <record id="group_servicios_escolares" model="res.groups">
        <field name="name">Servicios Escolares</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!--
        División de Estudios Profesionales / Coordinador (DEP-C-01SC, DEP-C-02SC).
        Grupo stub — puede difundir actividades y consultar expedientes de estudiantes.
    -->
    <record id="group_division_estudios" model="res.groups">
        <field name="name">División de Estudios Profesionales / Coordinador</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Record rules — actividad.complementaria
         ════════════════════════════════════════════════════════════════════

         Alumno     — solo ve actividades en catálogo (en_catalogo = True).
         Responsable — ve sus actividades asignadas y todo el catálogo.
         RAE        — ve solo las actividades donde está asignado como responsable
                      extraescolar (campo responsable_extraescolar_id).
         JD y Comité — el filtrado por departamento se gestiona en Python
                       (_search override); aquí solo se protegen escrituras ORM.
    -->

    <record id="rule_actividad_alumno" model="ir.rule">
        <field name="name">Alumno: solo actividades en catálogo</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">[('en_catalogo', '=', True)]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_alumno'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- RA: sus actividades asignadas Y todo el catálogo -->
    <record id="rule_actividad_responsable" model="ir.rule">
        <field name="name">Responsable: sus actividades asignadas y catálogo</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">
            ['|',
                ('responsable_actividad_id', '=', user.id),
                ('en_catalogo', '=', True)
            ]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        RAE: solo ve actividades donde está asignado como responsable_extraescolar_id.
        No tiene acceso al catálogo general (a diferencia del RA).
    -->
    <record id="rule_actividad_responsable_extraescolar" model="ir.rule">
        <field name="name">RAE: solo actividades asignadas como responsable extraescolar</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">
            [('responsable_extraescolar_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad_extraescolar'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        JD: la restricción de lectura se delega al domain de la acción.
        Aquí solo se protegen escrituras a nivel ORM como respaldo al guard
        de write() en Python.
    -->
    <record id="rule_actividad_jefe_departamento" model="ir.rule">
        <field name="name">Jefe de Departamento: escritura solo en su departamento</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">[('jefe_departamento_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_jefe_departamento'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        EmpleadoPermiso:
        - JD solo ve y gestiona el personal de su propio departamento.
        - Admin: sin record rule adicional (ve todo).
    -->
    <record id="rule_empleado_permiso_jefe" model="ir.rule">
        <field name="name">JD: solo gestiona personal de su departamento</field>
        <field name="model_id" ref="model_actividad_empleado_permiso"/>
        <field name="domain_force">[('departamento_id.jefe_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_jefe_departamento'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Personal por departamento — solo protege escrituras ORM -->
    <record id="rule_actividad_personal_sistemas" model="ir.rule">
        <field name="name">Personal Sistemas: escritura solo en su departamento</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">[('departamento_id.name', 'ilike', 'sistem')]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_personal_departamento_sistemas'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_actividad_personal_electrica" model="ir.rule">
        <field name="name">Personal Electrica: escritura solo en su departamento</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">[('departamento_id.name', 'ilike', 'electr')]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_personal_departamento_electrica'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_actividad_personal_biologia" model="ir.rule">
        <field name="name">Personal Biologia: escritura solo en su departamento</field>
        <field name="model_id" ref="model_actividad_complementaria"/>
        <field name="domain_force">[('departamento_id.name', 'ilike', 'biol')]</field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_personal_departamento_biologia'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Record rules — actividad.inscripcion
         RA  : sus actividades asignadas (responsable_actividad_id).
         RAE : sus actividades asignadas (responsable_extraescolar_id).
         JD/Admin: sin record rule — ven todo (control por CSV y acciones).
    ════════════════════════════════════════════════════════════════════ -->

    <record id="rule_inscripcion_responsable" model="ir.rule">
        <field name="name">RA: inscripciones de sus actividades asignadas</field>
        <field name="model_id" ref="model_actividad_inscripcion"/>
        <field name="domain_force">
            [('actividad_id.responsable_actividad_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_inscripcion_responsable_extraescolar" model="ir.rule">
        <field name="name">RAE: inscripciones de sus actividades asignadas</field>
        <field name="model_id" ref="model_actividad_inscripcion"/>
        <field name="domain_force">
            [('actividad_id.responsable_extraescolar_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad_extraescolar'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Record rules — actividad.asistencia
    ════════════════════════════════════════════════════════════════════ -->

    <record id="rule_asistencia_responsable" model="ir.rule">
        <field name="name">RA: asistencia de sus actividades asignadas</field>
        <field name="model_id" ref="model_actividad_asistencia"/>
        <field name="domain_force">
            [('actividad_id.responsable_actividad_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_asistencia_responsable_extraescolar" model="ir.rule">
        <field name="name">RAE: asistencia de sus actividades asignadas</field>
        <field name="model_id" ref="model_actividad_asistencia"/>
        <field name="domain_force">
            [('actividad_id.responsable_extraescolar_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('actividades_complementarias.group_responsable_actividad_extraescolar'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
