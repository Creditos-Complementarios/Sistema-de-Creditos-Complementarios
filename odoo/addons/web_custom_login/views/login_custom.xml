<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_custom" name="Login Custom" inherit_id="web.login_layout">

        <xpath expr="//div[hasclass('text-center','pb-3','border-bottom')]" position="replace">
            <div class="text-center pb-3 border-bottom mb-4">
                <img style="max-height:120px; max-width:100%; width:auto"
                     src="/web_custom_login/static/src/img/tecnm.png"
                     alt="TecNM"/>
            </div>
        </xpath>

    </template>
</odoo>