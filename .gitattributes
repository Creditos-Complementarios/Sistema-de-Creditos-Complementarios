# ============================================================
#  .gitattributes — Enforce LF line endings for all text files.
#  This prevents Windows developers from committing CRLF files
#  that cause issues inside Linux Docker containers.
# ============================================================

* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# XML / CSV / config
*.xml text eol=lf
*.csv text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Web assets
*.scss text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Docs
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
